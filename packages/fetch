#!/bin/bash
# Fetch – file downloader with i18n and progress bar

if locale 2>/dev/null | grep -qi ru; then
    USAGE="Использование: fetch <URL или magnet>"
    DOWNLOADING="Загрузка"
    SAVED="Файл сохранён"
    MAGNET_ADDED="Магнит добавлен, ожидание..."
    MAGNET_FAIL="Не удалось добавить магнит"
    NO_TRANSMISSION="Transmission не установлен"
    PROMPT="Введите URL или magnet: "
else
    USAGE="Usage: fetch <URL or magnet>"
    DOWNLOADING="Downloading"
    SAVED="File saved"
    MAGNET_ADDED="Magnet added, waiting..."
    MAGNET_FAIL="Failed to add magnet"
    NO_TRANSMISSION="Transmission not installed"
    PROMPT="Enter URL or magnet: "
fi

input="${1:-}"
[ -z "$input" ] && read -p "$PROMPT" input
[ -z "$input" ] && { echo "$USAGE"; exit 1; }

if [[ "$input" =~ ^magnet: ]]; then
    command -v transmission-remote >/dev/null || { echo "$NO_TRANSMISSION"; exit 1; }
    pgrep transmission-da >/dev/null || { transmission-daemon 2>/dev/null; sleep 2; }
    echo "$MAGNET_ADDED"
    out=$(transmission-remote -a "$input" 2>&1)
    id=$(echo "$out" | grep -oP '(?<="id":)\d+')
    [ -z "$id" ] && { echo "$MAGNET_FAIL"; exit 1; }
    while : ; do
        pct=$(transmission-remote -t "$id" -i 2>/dev/null | awk '/Percent Done:/{print $3}' | tr -d '%')
        [ "$pct" = "100" ] && break
        printf "\r%s: %s%%" "$DOWNLOADING" "$pct"
        sleep 2
    done
    echo ""
    dl_dir=$(transmission-remote -t "$id" -i | awk '/Location:/{print $2}')
    file=$(find "$dl_dir" -type f ! -name '*.torrent' | head -1)
    cp "$file" "./$(basename "$file")"
    echo "$SAVED $(basename "$file")"
    transmission-remote -t "$id" --remove &>/dev/null
else
    filename=$(basename "$input" | sed 's/?.*//')
    [ -z "$filename" ] && filename="downloaded_file"
    echo "$DOWNLOADING $filename..."
    curl -# -L -o "$filename" "$input"
    echo "$SAVED $(pwd)/$filename"
fi
