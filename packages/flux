#!/bin/bash
# Flux – network monitor (full on PC, ping-based speed estimation on Termux)
set -e
trap 'tput cnorm; clear; exit' INT TERM
tput civis

if [ -n "$PREFIX" ] && [ -d "$PREFIX" ]; then
    IS_TERMUX=true
else
    IS_TERMUX=false
fi

# ---------- i18n ----------
if locale 2>/dev/null | grep -qi ru; then
    TITLE_FULL="Flux – Сетевой монитор"
    TITLE_MOBILE="Flux-M – Мобильный монитор"
    EXIT_MSG="Нажмите Ctrl+C для выхода"
    DOWN="Вниз"
    UP="Вверх"
    LATENCY="Задержка"
    EST_SPEED="Оценка скорости"
    KB_S="КБ/с"
    MB_S="МБ/с"
else
    TITLE_FULL="Flux – Network Monitor"
    TITLE_MOBILE="Flux-M – Mobile Monitor"
    EXIT_MSG="Press Ctrl+C to quit"
    DOWN="Down"
    UP="Up"
    LATENCY="Latency"
    EST_SPEED="Est. Speed"
    KB_S="KB/s"
    MB_S="MB/s"
fi

# ========== full PC version ==========
flux_full() {
    iface="${1:-}"
    if [ -z "$iface" ]; then
        for if in wlan0 eth0 wlp2s0 enp2s0 enp3s0; do
            [ -f "/sys/class/net/$if/statistics/rx_bytes" ] && iface="$if" && break
        done
        if [ -z "$iface" ]; then
            echo "No interface found. Available:"
            ls /sys/class/net 2>/dev/null || echo "No /sys/class/net"
            echo "Specify interface: flux <interface>"
            exit 1
        fi
    fi
    if [ ! -f "/sys/class/net/$iface/statistics/rx_bytes" ]; then
        echo "Interface $iface not found."
        ls /sys/class/net
        exit 1
    fi
    prev_rx=$(cat /sys/class/net/$iface/statistics/rx_bytes)
    prev_tx=$(cat /sys/class/net/$iface/statistics/tx_bytes)
    while true; do
        sleep 1
        rx=$(cat /sys/class/net/$iface/statistics/rx_bytes)
        tx=$(cat /sys/class/net/$iface/statistics/tx_bytes)
        rx_diff=$((rx - prev_rx))
        tx_diff=$((tx - prev_tx))
        prev_rx=$rx; prev_tx=$tx
        rx_speed=$(awk "BEGIN {printf \"%.1f\", $rx_diff/1024}")
        tx_speed=$(awk "BEGIN {printf \"%.1f\", $tx_diff/1024}")
        clear
        echo "╔══════════════════════════════════════╗"
        printf "║  %-36s ║\n" "$TITLE_FULL"
        echo "╠══════════════════════════════════════╣"
        printf "║  Interface: %-27s ║\n" "$iface"
        printf "║  %s: %-8s %-4s                  ║\n" "$DOWN" "$rx_speed" "$KB_S"
        printf "║  %s: %-8s %-4s                  ║\n" "$UP" "$tx_speed" "$KB_S"
        echo "╠══════════════════════════════════════╣"
        max_bar=20
        rx_bar_len=$(awk "BEGIN {printf \"%d\", $rx_speed/10}")
        [ "$rx_bar_len" -gt "$max_bar" ] && rx_bar_len=$max_bar
        rx_bar=$(printf "%${rx_bar_len}s" | tr ' ' '#')
        printf "║  %-7s [%-20s] ║\n" "$DOWN" "$rx_bar"
        tx_bar_len=$(awk "BEGIN {printf \"%d\", $tx_speed/10}")
        [ "$tx_bar_len" -gt "$max_bar" ] && tx_bar_len=$max_bar
        tx_bar=$(printf "%${tx_bar_len}s" | tr ' ' '#')
        printf "║  %-7s [%-20s] ║\n" "$UP" "$tx_bar"
        echo "╚══════════════════════════════════════╝"
        echo "$EXIT_MSG"
    done
}

# ========== mobile version (ping-based speed estimation) ==========
flux_mobile() {
    clear
    local host="8.8.8.8"   # можно параметризовать позже
    # интерфейсы – просто список, без деталей трафика
    local ifaces
    ifaces=$(ifconfig 2>/dev/null | grep -E '^[a-z]' | awk '{print $1}' | tr '\n' ' ' || echo "none")

    while true; do
        # замеряем время пинга (один пакет, чтобы быстро)
        local rtt
        rtt=$(ping -c1 -W2 "$host" 2>/dev/null | grep -oP 'time=\K[0-9.]+' || echo "0")
        local rtt_ms="${rtt:-0}"
        # оценка скорости: 1/rtt * коэффициент (очень грубо)
        # Используем формулу: speed (KB/s) ≈ 1000 / rtt_ms (если rtt > 0), иначе 0
        local speed_kb=0
        if command -v bc &>/dev/null && [[ "$rtt_ms" =~ ^[0-9.]+$ ]] && (( $(echo "$rtt_ms > 0" | bc) )); then
            speed_kb=$(echo "scale=1; 1000 / $rtt_ms" | bc)
        else
            speed_kb="0"
        fi

        # пересчёт в МБ/с при большом значении
        local disp_speed disp_unit
        if (( $(echo "$speed_kb >= 1024" | bc 2>/dev/null || echo 0) )); then
            disp_speed=$(echo "scale=1; $speed_kb / 1024" | bc)
            disp_unit="$MB_S"
        else
            disp_speed="$speed_kb"
            disp_unit="$KB_S"
        fi

        # бар для скорости
        local max_bar=20
        local bar_len
        bar_len=$(echo "scale=0; $speed_kb / 50" | bc 2>/dev/null || echo 0)
        [ "$bar_len" -gt "$max_bar" ] && bar_len=$max_bar
        local bar
        bar=$(printf "%${bar_len}s" | tr ' ' '#')

        clear
        echo "╔══════════════════════════════════════╗"
        printf "║  %-36s ║\n" "$TITLE_MOBILE"
        echo "╠══════════════════════════════════════╣"
        printf "║  %s: %-6s ms                     ║\n" "$LATENCY" "$rtt_ms"
        printf "║  %s: %-6s %-4s                   ║\n" "$EST_SPEED" "$disp_speed" "$disp_unit"
        echo "╠══════════════════════════════════════╣"
        printf "║  %-7s [%-20s] ║\n" "$EST_SPEED" "$bar"
        echo "╠══════════════════════════════════════╣"
        printf "║  Interfaces: %-23s ║\n" "${ifaces:0:23}"
        echo "╚══════════════════════════════════════╝"
        echo "$EXIT_MSG"
        sleep 2
    done
}

# ========== main ==========
if $IS_TERMUX; then
    flux_mobile
else
    flux_full "$1"
fi
