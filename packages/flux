#!/bin/bash
# Flux – network monitor (full on PC, info panel on Termux)
set -e
trap 'tput cnorm; clear; exit' INT TERM
tput civis

if [ -n "$PREFIX" ] && [ -d "$PREFIX" ]; then
    IS_TERMUX=true
else
    IS_TERMUX=false
fi

# i18n
if locale 2>/dev/null | grep -qi ru; then
    TITLE_FULL="Flux – Сетевой монитор"
    TITLE_MOBILE="Flux-M – Информация о сети"
    EXIT="Нажмите Ctrl+C для выхода"
    IFACE_LABEL="Интерфейсы"
    IP_LABEL="IP-адреса"
    NO_ROOT_MSG="Для детального мониторинга требуется root-доступ."
else
    TITLE_FULL="Flux – Network Monitor"
    TITLE_MOBILE="Flux-M – Network Info"
    EXIT="Press Ctrl+C to quit"
    IFACE_LABEL="Interfaces"
    IP_LABEL="IP addresses"
    NO_ROOT_MSG="Detailed monitoring requires root access."
fi

# full PC version (unchanged)
flux_full() {
    iface="${1:-}"
    [ -z "$iface" ] && {
        for i in wlan0 eth0 wlp2s0 enp2s0 enp3s0; do
            [ -f "/sys/class/net/$i/statistics/rx_bytes" ] && iface="$i" && break
        done
    }
    [ -z "$iface" ] && { ls /sys/class/net 2>/dev/null; echo "Specify: flux <iface>"; exit 1; }
    prev_rx=$(cat /sys/class/net/$iface/statistics/rx_bytes)
    prev_tx=$(cat /sys/class/net/$iface/statistics/tx_bytes)
    while true; do
        sleep 1
        rx=$(cat /sys/class/net/$iface/statistics/rx_bytes)
        tx=$(cat /sys/class/net/$iface/statistics/tx_bytes)
        echo "↓ $(awk "BEGIN {printf \"%.1f\", ($rx-$prev_rx)/1024}") KB/s  ↑ $(awk "BEGIN {printf \"%.1f\", ($tx-$prev_tx)/1024}") KB/s"
        prev_rx=$rx; prev_tx=$tx
    done
}

# mobile version – только то, что доступно без root
flux_mobile() {
    clear
    printf '%s\n' "$TITLE_MOBILE"
    printf '%s\n' "$EXIT"
    echo "----------------------------------------"

    echo "$IFACE_LABEL:"
    ifconfig 2>/dev/null | grep -E '^[a-z]' | awk '{print "  "$1}' || echo "  none"
    echo ""

    echo "$IP_LABEL:"
    ifconfig 2>/dev/null | grep 'inet ' | awk '{print "  "$2}' || echo "  none"
    echo ""

    echo "$NO_ROOT_MSG"
    echo "----------------------------------------"
    # держим экран открытым до Ctrl+C
    while true; do sleep 10; done
}

if $IS_TERMUX; then
    flux_mobile
else
    flux_full "$1"
fi
