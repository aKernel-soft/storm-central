#!/bin/bash
# Flux – pure text monitor, no pseudo‑graphics
set -e
trap 'tput cnorm; clear; exit' INT TERM
tput civis

if [ -n "$PREFIX" ] && [ -d "$PREFIX" ]; then
    IS_TERMUX=true
else
    IS_TERMUX=false
fi

# i18n
if locale 2>/dev/null | grep -qi ru; then
    TITLE_FULL="Flux – Сетевой монитор"
    TITLE_MOBILE="Flux-M – Мобильный монитор"
    EXIT="Нажмите Ctrl+C для выхода"
    PING_LABEL="Задержка"
    SPEED_LABEL="Оценка скорости"
    IFACE_LABEL="Интерфейсы"
    NO_PING="ICMP заблокирован или нет сети. Показываю доступные интерфейсы."
else
    TITLE_FULL="Flux – Network Monitor"
    TITLE_MOBILE="Flux-M – Mobile Monitor"
    EXIT="Press Ctrl+C to quit"
    PING_LABEL="Latency"
    SPEED_LABEL="Est. speed"
    IFACE_LABEL="Interfaces"
    NO_PING="ICMP blocked or no network. Showing available interfaces."
fi

# full PC version (unchanged)
flux_full() {
    iface="${1:-}"
    [ -z "$iface" ] && {
        for i in wlan0 eth0 wlp2s0 enp2s0 enp3s0; do
            [ -f "/sys/class/net/$i/statistics/rx_bytes" ] && iface="$i" && break
        done
    }
    [ -z "$iface" ] && { ls /sys/class/net 2>/dev/null; echo "Specify: flux <iface>"; exit 1; }
    prev_rx=$(cat /sys/class/net/$iface/statistics/rx_bytes)
    prev_tx=$(cat /sys/class/net/$iface/statistics/tx_bytes)
    while true; do
        sleep 1
        rx=$(cat /sys/class/net/$iface/statistics/rx_bytes)
        tx=$(cat /sys/class/net/$iface/statistics/tx_bytes)
        echo "↓ $(awk "BEGIN {printf \"%.1f\", ($rx-$prev_rx)/1024}") KB/s  ↑ $(awk "BEGIN {printf \"%.1f\", ($tx-$prev_tx)/1024}") KB/s"
        prev_rx=$rx; prev_tx=$tx
    done
}

# mobile version – pure text, no boxes
flux_mobile() {
    clear
    printf '%s\n' "$TITLE_MOBILE"
    printf '%s\n' "$EXIT"
    echo "----------------------------------------"

    # список интерфейсов
    echo "$IFACE_LABEL:"
    ifconfig 2>/dev/null | grep -E '^[a-z]' | awk '{print "  "$1}' || echo "  none"

    local host="8.8.8.8"
    while true; do
        # пробуем пинг (один пакет, таймаут 1 сек)
        rtt=$(ping -c1 -W1 "$host" 2>/dev/null | grep -oP 'time=\K[0-9.]+' || true)
        if [ -n "$rtt" ] && [ "$rtt" != "0" ]; then
            # оценка скорости по задержке: 1000/rtt (очень грубо)
            speed=$(awk "BEGIN {printf \"%.1f\", 1000 / $rtt}")
            printf "\r%s: %s ms  |  %s: %s KB/s" "$PING_LABEL" "$rtt" "$SPEED_LABEL" "$speed"
        else
            printf "\r%s" "$NO_PING"
        fi
        sleep 2
    done
}

if $IS_TERMUX; then
    flux_mobile
else
    flux_full "$1"
fi
