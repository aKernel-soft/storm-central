#!/bin/bash
# Flux – network monitor (full on PC, mobile mode on Termux with live refresh)
set -e
trap 'tput cnorm; clear; exit' INT TERM
tput civis

if [ -n "$PREFIX" ] && [ -d "$PREFIX" ]; then
    IS_TERMUX=true
else
    IS_TERMUX=false
fi

# ========== i18n ==========
if locale 2>/dev/null | grep -qi ru; then
    TITLE_FULL="Flux – Сетевой монитор"
    TITLE_MOBILE="Flux-M – Мобильный монитор"
    IFACE_LABEL="Интерфейс:"
    DOWN="Вниз"
    UP="Вверх"
    EXIT_MSG="Нажмите Ctrl+C для выхода"
    NO_IFACE="Не указан интерфейс. Доступные:"
    SPECIFY="Укажите интерфейс: flux <интерфейс>"
    MOBILE_PING="Пинг"
    MOBILE_LOSS="Потери"
    MOBILE_RTT="Средняя задержка"
    MOBILE_SCANNING="Обновление каждые 2 сек..."
else
    TITLE_FULL="Flux – Network Monitor"
    TITLE_MOBILE="Flux-M – Mobile Monitor"
    IFACE_LABEL="Interface:"
    DOWN="Down"
    UP="Up"
    EXIT_MSG="Press Ctrl+C to quit"
    NO_IFACE="No interface specified. Available:"
    SPECIFY="Specify interface: flux <interface>"
    MOBILE_PING="Ping"
    MOBILE_LOSS="Loss"
    MOBILE_RTT="Avg RTT"
    MOBILE_SCANNING="Refreshing every 2s..."
fi

# ========== FULL PC VERSION (unchanged) ==========
flux_full() {
    iface="${1:-}"
    if [ -z "$iface" ]; then
        for if in wlan0 eth0 wlp2s0 enp2s0 enp3s0; do
            [ -f "/sys/class/net/$if/statistics/rx_bytes" ] && iface="$if" && break
        done
        if [ -z "$iface" ]; then
            echo "$NO_IFACE"
            ls /sys/class/net 2>/dev/null || echo "No /sys/class/net"
            echo "$SPECIFY"
            exit 1
        fi
    fi
    if [ ! -f "/sys/class/net/$iface/statistics/rx_bytes" ]; then
        echo "Interface $iface not found."
        ls /sys/class/net
        exit 1
    fi
    prev_rx=$(cat /sys/class/net/$iface/statistics/rx_bytes)
    prev_tx=$(cat /sys/class/net/$iface/statistics/tx_bytes)
    while true; do
        sleep 1
        rx=$(cat /sys/class/net/$iface/statistics/rx_bytes)
        tx=$(cat /sys/class/net/$iface/statistics/tx_bytes)
        rx_diff=$((rx - prev_rx))
        tx_diff=$((tx - prev_tx))
        prev_rx=$rx; prev_tx=$tx
        rx_speed=$(awk "BEGIN {printf \"%.1f\", $rx_diff/1024}")
        tx_speed=$(awk "BEGIN {printf \"%.1f\", $tx_diff/1024}")
        clear
        echo "╔══════════════════════════════════════╗"
        printf "║  %-36s ║\n" "$TITLE_FULL"
        echo "╠══════════════════════════════════════╣"
        printf "║  %s %-31s ║\n" "$IFACE_LABEL" "$iface"
        printf "║  %s: %-8s KB/s                  ║\n" "$DOWN" "$rx_speed"
        printf "║  %s: %-8s KB/s                  ║\n" "$UP" "$tx_speed"
        echo "╠══════════════════════════════════════╣"
        max_bar=20
        rx_bar_len=$(awk "BEGIN {printf \"%d\", $rx_speed/10}")
        [ "$rx_bar_len" -gt "$max_bar" ] && rx_bar_len=$max_bar
        rx_bar=$(printf "%${rx_bar_len}s" | tr ' ' '#')
        printf "║  %-7s [%-20s] ║\n" "$DOWN" "$rx_bar"
        tx_bar_len=$(awk "BEGIN {printf \"%d\", $tx_speed/10}")
        [ "$tx_bar_len" -gt "$max_bar" ] && tx_bar_len=$max_bar
        tx_bar=$(printf "%${tx_bar_len}s" | tr ' ' '#')
        printf "║  %-7s [%-20s] ║\n" "$UP" "$tx_bar"
        echo "╚══════════════════════════════════════╝"
        echo "$EXIT_MSG"
    done
}

# ========== MOBILE VERSION (live ping monitor) ==========
flux_mobile() {
    clear
    while true; do
        # собираем данные
        ifaces=$(ifconfig 2>/dev/null | grep -E '^[a-z]' | awk '{print $1}' | tr '\n' ' ' || echo "none")
        # пинг до 8.8.8.8: одна строка с потерями и средней задержкой
        ping_out=$(ping -c2 -W1 8.8.8.8 2>&1 | tail -1)
        loss=$(echo "$ping_out" | grep -oP '\d+(?=% packet loss)' || echo "100")
        rtt=$(echo "$ping_out" | grep -oP '\d+\.\d+/\d+\.\d+/\d+\.\d+' | cut -d/ -f2 || echo "?")
        # рисуем
        clear
        echo "╔══════════════════════════════════════╗"
        printf "║  %-36s ║\n" "$TITLE_MOBILE"
        echo "╠══════════════════════════════════════╣"
        printf "║  %s %-31s ║\n" "$MOBILE_PING:" "$rtt ms"
        printf "║  %s %-31s ║\n" "$MOBILE_LOSS:" "$loss%"
        printf "║  %s: %-29s ║\n" "$MOBILE_RTT" "$rtt ms"
        echo "╠══════════════════════════════════════╣"
        printf "║  %-36s ║\n" "Интерфейсы:"
        for if in $ifaces; do
            printf "║    - %-32s ║\n" "$if"
        done
        echo "╚══════════════════════════════════════╝"
        echo "$MOBILE_SCANNING"
        sleep 2
    done
}

# ========== MAIN ==========
if $IS_TERMUX; then
    flux_mobile
else
    flux_full "$1"
fi
