#!/bin/bash
# Gale – clean text weather with saved default city

CONFIG="$HOME/.gale_city"

if locale 2>/dev/null | grep -qi ru; then
    PROMPT_CITY="Введите город по умолчанию: "
    PROMPT_NO_CITY="Город не задан. Введите город сейчас: "
    SAVED="Город сохранён:"
    FETCHING="Загрузка погоды для"
    MENU_TITLE="Gale – Погода"
    OPT_NOW="[1] Текущая погода"
    OPT_FORECAST="[2] Прогноз на 3 дня"
    OPT_SET="[3] Сменить город"
    OPT_QUIT="[q] Выход"
    CHOOSE="Выберите действие: "
else
    PROMPT_CITY="Enter default city: "
    PROMPT_NO_CITY="No default city set. Enter city now: "
    SAVED="City saved:"
    FETCHING="Fetching weather for"
    MENU_TITLE="Gale – Weather"
    OPT_NOW="[1] Current weather"
    OPT_FORECAST="[2] 3-day forecast"
    OPT_SET="[3] Change city"
    OPT_QUIT="[q] Quit"
    CHOOSE="Choose an option: "
fi

city="${1:-}"

if [ -z "$city" ]; then
    if [ -f "$CONFIG" ]; then
        city=$(cat "$CONFIG")
    else
        read -p "$PROMPT_NO_CITY" city
        [ -z "$city" ] && city="Moscow"
        echo "$city" > "$CONFIG"
        echo "$SAVED $city"
    fi
fi

show_menu() {
    clear
    echo "=========================================="
    echo "  $MENU_TITLE  |  $city"
    echo "=========================================="
    echo "  $OPT_NOW"
    echo "  $OPT_FORECAST"
    echo "  $OPT_SET"
    echo "  $OPT_QUIT"
    echo "=========================================="
    echo ""
    printf "%s" "$CHOOSE"
}

# Функция для получения чистого текста погоды
get_current_weather() {
    local city="$1"
    curl -s "wttr.in/${city}?format=%l:+%t+%w,+%h\\n"
}

get_forecast() {
    local city="$1"
    # Получаем прогноз в одну строку на каждый день
    curl -s "wttr.in/${city}?format=3" | sed 's/┌.*//g;s/├.*//g;s/└.*//g;s/│.*//g;s/ *$//g' | grep -v '^$' | head -6
}

if [ -z "$1" ]; then
    while true; do
        show_menu
        read -r choice
        case "$choice" in
            1)
                echo "$FETCHING $city..."
                get_current_weather "$city"
                echo ""
                read -p "Press Enter to continue..."
                ;;
            2)
                echo "$FETCHING $city (3 days)..."
                get_forecast "$city"
                echo ""
                read -p "Press Enter to continue..."
                ;;
            3)
                read -p "$PROMPT_CITY" new_city
                [ -n "$new_city" ] && echo "$new_city" > "$CONFIG" && city="$new_city" && echo "$SAVED $new_city"
                sleep 1
                ;;
            q|Q)
                exit 0
                ;;
        esac
    done
else
    echo "$FETCHING $city..."
    get_current_weather "$city"
fi
