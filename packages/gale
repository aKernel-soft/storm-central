#!/bin/bash
# Gale – weather with ASCII art for current weather and clean 3-day forecast

CONFIG="$HOME/.gale_city"

if locale 2>/dev/null | grep -qi ru; then
    PROMPT_CITY="Введите город по умолчанию: "
    PROMPT_NO_CITY="Город не задан. Введите город сейчас: "
    SAVED="Город сохранён:"
    FETCHING="Загрузка погоды для"
    MENU_TITLE="Gale – Погода"
    OPT_NOW="[1] Сейчас"
    OPT_FORECAST="[2] Прогноз на 3 дня"
    OPT_SET="[3] Сменить город"
    OPT_QUIT="[q] Выход"
    CHOOSE="Выберите действие: "
    TODAY="Сегодня"
    TOMORROW="Завтра"
    DAY_AFTER="Послезавтра"
else
    PROMPT_CITY="Enter default city: "
    PROMPT_NO_CITY="No default city set. Enter city now: "
    SAVED="City saved:"
    FETCHING="Fetching weather for"
    MENU_TITLE="Gale – Weather"
    OPT_NOW="[1] Now"
    OPT_FORECAST="[2] 3-day forecast"
    OPT_SET="[3] Change city"
    OPT_QUIT="[q] Quit"
    CHOOSE="Choose an option: "
    TODAY="Today"
    TOMORROW="Tomorrow"
    DAY_AFTER="Day after tomorrow"
fi

city="${1:-}"

if [ -z "$city" ]; then
    if [ -f "$CONFIG" ]; then
        city=$(cat "$CONFIG")
    else
        read -p "$PROMPT_NO_CITY" city
        [ -z "$city" ] && city="Moscow"
        echo "$city" > "$CONFIG"
        echo "$SAVED $city"
    fi
fi

show_menu() {
    clear
    echo "=========================================="
    echo "  $MENU_TITLE  |  $city"
    echo "=========================================="
    echo "  $OPT_NOW"
    echo "  $OPT_FORECAST"
    echo "  $OPT_SET"
    echo "  $OPT_QUIT"
    echo "=========================================="
    echo ""
    printf "%s" "$CHOOSE"
}

if [ -z "$1" ]; then
    while true; do
        show_menu
        read -r choice
        case "$choice" in
            1)
                # Current weather with ASCII art
                curl -s "wttr.in/${city}?0q"
                read -p "Press Enter to continue..."
                ;;
            2)
                echo "$FETCHING $city (3 days)..."
                # Today
                echo ""
                echo "  $TODAY:"
                curl -s "wttr.in/${city}?format=%l:+%t+%w,+%h\\n"
                # Tomorrow
                tomorrow=$(date -d "+1 day" +%Y-%m-%d)
                echo ""
                echo "  $TOMORROW:"
                curl -s "wttr.in/${city}?format=%l:+%t+%w,+%h&date=$tomorrow\\n"
                # Day after tomorrow
                day_after=$(date -d "+2 days" +%Y-%m-%d)
                echo ""
                echo "  $DAY_AFTER:"
                curl -s "wttr.in/${city}?format=%l:+%t+%w,+%h&date=$day_after\\n"
                echo ""
                read -p "Press Enter to continue..."
                ;;
            3)
                read -p "$PROMPT_CITY" new_city
                [ -n "$new_city" ] && echo "$new_city" > "$CONFIG" && city="$new_city" && echo "$SAVED $new_city"
                sleep 1
                ;;
            q|Q)
                exit 0
                ;;
        esac
    done
else
    # Quick mode: current weather only
    curl -s "wttr.in/${city}?0q"
fi
