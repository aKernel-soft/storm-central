#!/bin/bash
# Eho – простой чат (сервер/клиент)
# Работает на Termux и Linux без зависимостей

if locale 2>/dev/null | grep -qi ru; then
    USAGE="Использование: eho server <порт>   |   eho client <хост> <порт>"
    SERVER_START="Eho сервер запущен на порту"
    CLIENT_START="Eho клиент подключился к"
    EXIT_HELP="Введите /quit для выхода."
    CONNECTED="Клиент подключился"
else
    USAGE="Usage: eho server <port>   |   eho client <host> <port>"
    SERVER_START="Eho server listening on port"
    CLIENT_START="Eho client connected to"
    EXIT_HELP="Type /quit to exit."
    CONNECTED="Client connected"
fi

case "${1:-}" in
    server)
        port="${2:-1234}"
        echo "$SERVER_START $port"
        echo "$EXIT_HELP"
        # Принимаем входящие соединения и выводим всё на экран
        while true; do
            nc -l -p "$port" 2>/dev/null || nc -l "$port" 2>/dev/null || {
                # Если nc не поддерживает -p, пробуем другой синтаксис
                nc -l "$port"
            }
            echo "$CONNECTED"
        done
        ;;
    client)
        host="${2:-localhost}"
        port="${3:-1234}"
        echo "$CLIENT_START $host:$port"
        echo "$EXIT_HELP"
        # Отправляем ввод пользователя на сервер, читаем ответ (односторонний чат)
        nc "$host" "$port"
        ;;
    help|--help|-h)
        echo -e "$USAGE"
        ;;
    *)
        echo -e "$USAGE"
        ;;
esac
