#!/bin/bash
# Recon – network scanner with i18n

if locale 2>/dev/null | grep -qi ru; then
    USAGE="Использование: recon <CIDR> (например, 192.168.1.0/24)"
    SCANNING="Сканирование сети"
    HOST_UP="Хост"
    HOST_UP_SUFFIX="активен"
else
    USAGE="Usage: recon <CIDR> (e.g. 192.168.1.0/24)"
    SCANNING="Scanning network"
    HOST_UP="Host"
    HOST_UP_SUFFIX="is up"
fi

[ -z "$1" ] && { echo "$USAGE"; exit 1; }
IFS='./' read -r ip mask <<< "$1"
base="${ip%.*}"
echo "$SCANNING $base.0/$mask..."
for i in {1..254}; do
    ( ping -c1 -W1 "$base.$i" &>/dev/null && echo "$HOST_UP $base.$i $HOST_UP_SUFFIX" ) &
done
wait
